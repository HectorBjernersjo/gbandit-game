{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "headers": {
                "Authorization": "Bearer {env:CONTEXT7_API_KEY}"
            },
            "enabled": true
        },

        "chrome-devtools": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "chrome-devtools-mcp@latest",
                "--browser-url=http://127.0.0.1:{env:CHROME_DEBUG_PORT}"
            ],
            "enabled": true
        }
    }
}
