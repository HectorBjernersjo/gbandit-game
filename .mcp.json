{
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "mcp-remote",
                "https://mcp.context7.com/mcp",
                "--header",
                "Authorization: Bearer ${CONTEXT7_API_KEY}"
            ]
        },
        "chrome-devtools": {
            "type": "stdio",
            "command": "chrome-devtools-mcp",
            "args": [
                "--browser-url=http://127.0.0.1:${CHROME_DEBUG_PORT}"
            ],
            "env": {}
        }
    }
}
